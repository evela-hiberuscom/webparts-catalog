      "architecture": {
        "webPart": "ProjectStatusWebPart",
        "pattern": "SPFx React + repository + status normalizer",
        "components": [
          "ProjectStatus",
          "ProjectStatusRow",
          "ProjectStatusFilters"
        ],
        "services": [
          "ProjectStatusService",
          "ProjectStatusNormalizer"
        ],
        "repositories": [
          "ProjectsRepository"
        ]
      },
      "contracts": {
        "IWebPartProps": {
          "dataSourceTypes": "('SharePointList'|'Planner'|'JsonUrl'|'StaticConfig')[]",
          "listTitleOrUrl": "string",
          "maxItems": "number",
          "defaultStatusFilter": "string|undefined"
        },
        "IProjectStatusItem": {
          "id": "string",
          "title": "string",
          "status": "green|amber|red|unknown",
          "owner": "string|null",
          "relevantDate": "string|null",
          "openUrl": "string|null"
        },
        "IViewModel": {
          "items": "IProjectStatusItem[]",
          "hasPartialData": "boolean"
        }
      },
      "executionFlow": [
        "leer props",
        "leer proyectos desde orígenes",
        "normalizar estado/fecha/owner",
        "aplicar filtro por estado",
        "ordenar",
        "limitar y renderizar"
      ],
      "algorithms": {
        "sort": "status severity desc + relevantDate asc/null-last",
        "normalizeStatus": "mapear valores de origen a green/amber/red/unknown"
      },
      "performance": {
        "cache": "por origen",
        "retry": "1-2 reintentos"
      },
      "errorMatrix": [
        {
          "condition": "sin relevantDate",
          "uiState": "ready/partialData"
        },
        {
          "condition": "sin openUrl",
          "uiState": "partialData"
        },
        {
          "condition": "status desconocido",
          "uiState": "ready"
        }
      ],
