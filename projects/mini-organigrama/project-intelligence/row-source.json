      "meta": {
        "id": "mini-org-chart",
        "name": "Mini organigrama",
        "version": "1.0.0",
        "artifactType": "SPFxWebPart",
        "domain": "SharePoint Online",
        "status": "ready-for-implementation"
      },
      "summary": {
        "oneLiner": "Muestra una jerarquía simple de manager-equipo o una cadena corta de reporting para dar contexto organizativo.",
        "productGoal": "Ayudar a entender relaciones básicas de reporting sin un organigrama completo."
      },
      "problem": {
        "business": "No siempre es fácil entender cómo encaja un equipo o una persona dentro de la estructura.",
        "operational": "Muchas páginas necesitan un contexto jerárquico ligero, no un org chart completo."
      },
      "objectives": {
        "primary": [
          "Mostrar relaciones jerárquicas simples",
          "Permitir abrir perfil de manager o miembros",
          "Representar una cadena corta o árbol pequeño"
        ],
        "secondary": [
          "Destacar manager principal",
          "Servir como bloque de contexto organizativo"
        ]
      },
      "users": [
        {
          "role": "Empleado",
          "needs": [
            "entender quién reporta a quién a alto nivel"
          ]
        },
        {
          "role": "Manager",
          "needs": [
            "mostrar estructura mínima del área"
          ]
        }
      ],
      "scope": {
        "in": [
          "Manager",
          "miembros directos o cadena corta",
          "Acción abrir perfil"
        ],
        "out": [
          "organigrama corporativo completo",
          "navegación profunda de varios niveles ilimitados"
        ]
      },
      "useCases": [
        {
          "id": "CU-01",
          "name": "Ver manager y equipo directo",
          "actor": "Empleado"
        },
        {
          "id": "CU-02",
          "name": "Abrir perfil de una persona del organigrama",
          "actor": "Empleado"
        }
      ],
      "functionalRequirements": [
        {
          "id": "RF-01",
          "text": "Mostrar manager principal y miembros directos o una cadena corta según configuración."
        },
        {
          "id": "RF-02",
          "text": "Mostrar nombre, rol y foto cuando existan."
        },
        {
          "id": "RF-03",
          "text": "Permitir abrir perfil cuando exista URL."
        },
        {
          "id": "RF-04",
          "text": "Gestionar loading, empty, partialData y error."
        }
      ],
      "nonFunctionalRequirements": [
        {
          "id": "RNF-01",
          "text": "Debe ser visualmente simple y no sobrecargar la página."
        },
        {
          "id": "RNF-02",
          "text": "Debe degradar con gracia cuando falten relaciones jerárquicas."
        }
      ],
      "businessRules": [
        "Si falta foto, usar avatar por defecto.",
        "Si falta relación jerárquica de un nodo, mostrarlo como aislado o parcial.",
        "El manager principal siempre debe ir primero si existe."
      ],
