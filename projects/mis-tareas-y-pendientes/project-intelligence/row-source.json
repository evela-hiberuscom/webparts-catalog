      "meta": {
        "id": "my-tasks-and-pending",
        "name": "Mis tareas y pendientes",
        "version": "1.0.0",
        "artifactType": "SPFxWebPart",
        "domain": "SharePoint Online",
        "status": "ready-for-implementation"
      },
      "summary": {
        "oneLiner": "Agrega tareas y pendientes personales desde distintas fuentes corporativas en una vista única y accionable.",
        "productGoal": "Reducir la fragmentación de trabajo pendiente y permitir al usuario ver rápidamente qué debe atender a continuación."
      },
      "problem": {
        "business": "Las tareas suelen estar dispersas entre Planner, listas, To Do u otras fuentes.",
        "operational": "El usuario pierde contexto cambiando entre herramientas y puede olvidar tareas relevantes."
      },
      "objectives": {
        "primary": [
          "Unificar tareas personales en una sola vista",
          "Ordenar por urgencia o vencimiento",
          "Permitir abrir la tarea en su sistema origen",
          "Distinguir vencidas, próximas y completadas ocultables"
        ],
        "secondary": [
          "Filtrar por origen o categoría",
          "Mostrar conteos por estado",
          "Servir como bloque personal de portada"
        ]
      },
      "users": [
        {
          "role": "Empleado",
          "needs": [
            "ver tareas pendientes en una sola tarjeta",
            "priorizar por vencimiento"
          ]
        },
        {
          "role": "Manager individual contributor",
          "needs": [
            "detectar carga pendiente rápidamente"
          ]
        }
      ],
      "scope": {
        "in": [
          "Agregación de tareas desde fuentes soportadas",
          "Lista de tareas abiertas",
          "Orden por vencimiento o prioridad",
          "Filtros simples",
          "Acción abrir tarea"
        ],
        "out": [
          "Edición inline compleja",
          "reescritura de tareas en todos los orígenes",
          "automatización de priorización avanzada"
        ]
      },
      "useCases": [
        {
          "id": "CU-01",
          "name": "Ver mis tareas hoy",
          "actor": "Empleado"
        },
        {
          "id": "CU-02",
          "name": "Detectar vencidas",
          "actor": "Empleado"
        },
        {
          "id": "CU-03",
          "name": "Abrir tarea en origen",
          "actor": "Empleado"
        }
      ],
      "functionalRequirements": [
        {
          "id": "RF-01",
          "text": "Mostrar tareas pendientes agregadas desde uno o varios orígenes configurados."
        },
        {
          "id": "RF-02",
          "text": "Permitir ordenar por vencimiento o prioridad."
        },
        {
          "id": "RF-03",
          "text": "Permitir filtrar por origen, estado o categoría si los datos existen."
        },
        {
          "id": "RF-04",
          "text": "Marcar tareas vencidas y próximas a vencer."
        },
        {
          "id": "RF-05",
          "text": "Permitir abrir la tarea en el sistema origen."
        },
        {
          "id": "RF-06",
          "text": "Gestionar loading, empty, partialData y error."
