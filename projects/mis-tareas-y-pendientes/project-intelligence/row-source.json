    "technicalJson": {
      "architecture": {
        "webPart": "MyTasksAndPendingWebPart",
        "pattern": "SPFx React + adapters por origen + aggregator",
        "components": [
          "MyTasksAndPending",
          "TaskSummaryChips",
          "TaskList",
          "TaskFilters"
        ],
        "services": [
          "TasksAggregationService",
          "TaskGroupingService"
        ],
        "repositories": [
          "PlannerTasksRepository",
          "ToDoTasksRepository",
          "SharePointTasksRepository"
        ]
      },
      "contracts": {
        "IWebPartProps": {
          "dataSourceTypes": "('Planner'|'ToDo'|'SharePointList'|'JsonUrl')[]",
          "showCompleted": "boolean",
          "maxItems": "number",
          "defaultSort": "dueDate|priority|source"
        },
        "ITaskItem": {
          "id": "string",
          "title": "string",
          "source": "string",
          "status": "open|completed|unknown",
          "dueDate": "string|null",
          "priority": "low|medium|high|unknown",
          "openUrl": "string|null",
          "group": "overdue|today|soon|someday|noDate"
        },
        "IViewModel": {
          "items": "ITaskItem[]",
          "counts": "{overdue:number;today:number;soon:number;noDate:number}",
          "hasPartialData": "boolean"
        }
      },
      "executionFlow": [
        "leer props",
        "leer tareas desde cada origen",
        "normalizar a ITaskItem",
        "filtrar completed si procede",
        "clasificar por grupo temporal",
        "ordenar",
        "renderizar"
      ],
      "algorithms": {
        "grouping": "overdue/today/soon/noDate según dueDate y now",
        "sort": "group asc + dueDate asc + priority desc o según configuración"
      },
      "performance": {
        "cache": "por origen y usuario actual",
        "retry": "1-2 reintentos por origen",
        "limits": "maxItems aplicado tras agregación y ordenación"
      },
      "errorMatrix": [
        {
          "condition": "origen individual falla",
          "uiState": "partialData"
        },
        {
          "condition": "sin dueDate",
          "uiState": "ready"
        },
        {
          "condition": "sin openUrl",
          "uiState": "partialData"
        }
      ],
      "security": {
        "mode": "readOnly",
        "rules": [
          "no mezclar datos de otros usuarios",
          "sanitizar openUrl"
        ]
      },
