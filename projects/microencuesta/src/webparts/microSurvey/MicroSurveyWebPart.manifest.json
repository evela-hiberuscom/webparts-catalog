{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx/client-side-web-part-manifest.schema.json",
  "id": "31d680f8-b21d-46d5-805f-751af6b12f37",
  "alias": "MicroSurveyWebPart",
  "componentType": "WebPart",

  // The "*" signifies that the version should be taken from the package.json
  "version": "*",
  "manifestVersion": 2,

  // If true, the component can only be installed on sites where Custom Script is allowed.
  // Components that allow authors to embed arbitrary script code should set this to true.
  // https://support.office.com/en-us/article/Turn-scripting-capabilities-on-or-off-1f2c515f-5d7e-448a-9fd7-835da935584f
  "requiresCustomScript": false,
  "supportedHosts": ["SharePointWebPart", "TeamsPersonalApp", "TeamsTab", "SharePointFullPage"],
  "supportsThemeVariants": true,

  "preconfiguredEntries": [{
    "groupId": "5c03119e-3074-46fd-976b-c60198311f70", // Advanced
    "group": { "default": "Advanced" },
    "title": { "default": "Microencuesta" },
    "description": { "default": "Lanza una pregunta rápida de una sola respuesta para recoger feedback ligero y frecuente." },
    "officeFabricIconFontName": "Feedback",
    "properties": {
      "description": "Recoge una opinion rapida sin sacar al usuario del flujo de la pagina.",
      "dataSourceType": "StaticConfig",
      "listTitleOrUrl": "Poll Questions",
      "responsesListTitleOrUrl": "Poll Responses",
      "apiEndpointUrl": "",
      "questionText": "¿Te resulta util la home actual?",
      "optionsCsv": "Si;No;Parcialmente",
      "oneResponsePerUser": true
    }
  }]
}
