        "webPart": "AutomaticWeeklySummaryWebPart",
        "pattern": "SPFx React + multi-source aggregator + date range filter",
        "components": [
          "AutomaticWeeklySummary",
          "WeeklyHighlightItem"
        ],
        "services": [
          "WeeklySummaryAggregationService",
          "WeeklyRangeResolver"
        ],
        "repositories": [
          "SummarySourceRepository"
        ]
      },
      "contracts": {
        "IWebPartProps": {
          "dataSourceTypes": "('SharePointList'|'News'|'Milestones'|'Incidents'|'JsonUrl')[]",
          "periodMode": "currentWeek|previousWeek|customRange",
          "maxItems": "number"
