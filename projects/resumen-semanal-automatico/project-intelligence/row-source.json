          "items": "IWeeklyHighlight[]",
          "periodLabel": "string",
          "hasPartialData": "boolean"
        }
      },
      "executionFlow": [
        "leer props",
        "resolver rango temporal",
        "leer fuentes configuradas",
        "normalizar elementos a highlights",
        "filtrar por periodo",
        "ordenar y limitar",
        "renderizar"
      ],
      "algorithms": {
        "range": "currentWeek/previousWeek/customRange resolver en timezone local",
        "sort": "priority desc/null-last + date desc"
      },
      "performance": {
        "cache": "por periodo y origen",
        "retry": "1-2 reintentos por origen"
      },
