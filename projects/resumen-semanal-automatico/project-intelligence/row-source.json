      "meta": {
        "id": "automatic-weekly-summary",
        "name": "Resumen semanal automático",
        "version": "1.0.0",
        "artifactType": "SPFxWebPart",
        "domain": "SharePoint Online",
        "status": "ready-for-implementation"
      },
      "summary": {
        "oneLiner": "Resume noticias, hitos, incidencias o tareas destacadas de una semana en una tarjeta o bloque compacto.",
        "productGoal": "Reducir la sobrecarga informativa ofreciendo una síntesis semanal legible y útil."
      },
      "problem": {
        "business": "La información diaria se dispersa y cuesta quedarse con lo realmente importante de la semana.",
        "operational": "Los equipos necesitan una pieza que resuma señales clave sin revisar múltiples componentes por separado."
      },
      "objectives": {
        "primary": [
          "Mostrar resumen semanal de elementos relevantes",
          "Combinar señales de varias fuentes cuando existan",
          "Permitir abrir detalle de elementos destacados"
        ],
        "secondary": [
          "Servir como digest reusable en portada o páginas de área",
          "Mostrar fecha de periodo resumido"
        ]
      },
      "users": [
        {
          "role": "Empleado",
          "needs": [
            "entender rápidamente lo más importante de la semana"
          ]
        },
        {
          "role": "Lead/Comms",
          "needs": [
            "visibilizar resumen ejecutivo semanal"
          ]
        }
      ],
      "scope": {
        "in": [
          "Resumen de una semana",
          "Bloques destacados o lista corta de highlights",
          "Periodo temporal visible",
          "Acción abrir detalle de un highlight"
        ],
        "out": [
          "resumen generativo libre en V1",
          "redacción automática avanzada sin fuente estructurada"
        ]
      },
      "useCases": [
        {
          "id": "CU-01",
          "name": "Leer highlights semanales",
          "actor": "Empleado"
        },
        {
          "id": "CU-02",
          "name": "Abrir un highlight concreto",
          "actor": "Empleado"
        }
      ],
      "functionalRequirements": [
        {
          "id": "RF-01",
          "text": "Mostrar highlights de la semana actual o del periodo configurado."
        },
        {
          "id": "RF-02",
          "text": "Mostrar título, tipo y fecha cuando existan."
        },
        {
          "id": "RF-03",
          "text": "Permitir abrir detalle de cada highlight cuando exista URL."
        },
        {
          "id": "RF-04",
          "text": "Combinar varias fuentes si están configuradas."
        },
        {
          "id": "RF-05",
          "text": "Gestionar loading, empty, partialData y error."
        }
      ],
      "nonFunctionalRequirements": [
        {
          "id": "RNF-01",
          "text": "Debe ser compacto y de lectura rápida."
        },
        {
          "id": "RNF-02",
          "text": "Debe manejar datos heterogéneos con normalización simple."
        }
      ],
      "businessRules": [
        "Solo se incluyen elementos dentro del rango temporal configurado.",
        "Los highlights se ordenan por prioridad de origen o fecha descendente.",
        "Si falta URL, el highlight sigue siendo informativo."
      ],
