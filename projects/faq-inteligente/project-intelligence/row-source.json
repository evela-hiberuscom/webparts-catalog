      "entities": {
        "Faq": {
          "id": "string",
          "question": "string",
          "answer": "string|null",
          "category": "string|null",
          "relatedUrl": "string|null",
          "featured": "boolean|null"
        }
      },
      "mappings": {
        "category": "string o General",
        "featured": "boolean default false"
      },
      "validationRules": [
        "question requerida",
        "answer recomendada"
      ],
      "accuracyPolicy": {
        "exact": "pregunta, respuesta y categoría presentes",
        "partial": "falta answer, category o relatedUrl"
      },
      "fallbacks": [
        "sin category => General",
        "sin relatedUrl => sin acción secundaria",
        "sin answer => item parcial"
      ],
      "exampleOutput": {
        "items": [
          {
            "question": "¿Cómo pido vacaciones?",
            "answer": "Desde el portal RRHH...",
            "category": "RRHH",
            "relatedUrl": "/sites/hr/vacaciones"
          }
        ]
      },
      "testDataset": {
        "minimumScenarios": [
          "faq básica",
          "sin categoría",
          "sin enlace",
          "sin respuesta",
          "empty"
        ]
      }
    },
    "technicalJson": {
      "architecture": {
        "webPart": "SmartFaqWebPart",
        "pattern": "SPFx React + repository + search/filter service",
        "components": [
          "SmartFaq",
          "FaqSearchBar",
          "FaqCategoryFilter",
          "FaqAccordionItem"
        ],
        "services": [
          "FaqCatalogService",
          "FaqFilterService"
        ],
        "repositories": [
          "FaqRepository"
        ]
      },
      "contracts": {
        "IWebPartProps": {
          "dataSourceType": "SharePointList|JsonUrl|StaticConfig",
          "listTitleOrUrl": "string",
          "enableSearch": "boolean",
          "defaultCategory": "string|undefined",
          "maxItems": "number"
        },
        "IFaqItem": {
          "id": "string",
          "question": "string",
          "answer": "string|null",
          "category": "string|null",
          "relatedUrl": "string|null",
          "featured": "boolean"
        },
        "IViewModel": {
          "items": "IFaqItem[]",
          "categories": "string[]",
          "hasPartialData": "boolean"
        }
      },
      "executionFlow": [
        "leer props",
        "resolver origen",
        "leer FAQs",
        "normalizar categorías y featured",
        "aplicar búsqueda y filtro",
        "renderizar acordeón"
      ],
      "algorithms": {
        "filter": "por categoría y texto sobre question/answer",
        "sort": "featured primero + question asc"
      },
      "performance": {
        "cache": "por origen",
        "retry": "1-2 reintentos",
        "limit": "maxItems tras filtro"
      },
      "errorMatrix": [
        {
          "condition": "sin answer",
          "uiState": "partialData"
        },
        {
          "condition": "sin category",
          "uiState": "ready"
        }
      ],
      "security": {
        "mode": "readOnly",
        "rules": [
          "sanitizar relatedUrl",
          "no renderizar HTML inseguro en respuestas"
        ]
      },
