      "summary": {
        "oneLiner": "Ofrece ayuda contextual breve según la página, sección o tipo de contenido donde se encuentre el usuario.",
        "productGoal": "Reducir dudas y orientar al usuario sin sacarlo del contexto actual."
      },
      "problem": {
        "business": "Muchas páginas requieren orientación, pero un FAQ general o una guía completa resultan excesivos.",
        "operational": "Se necesita ayuda puntual, embebida y relevante al contexto actual."
      },
      "objectives": {
        "primary": [
          "Mostrar ayuda contextual según página o contexto configurado",
          "Sugerir siguientes pasos o recursos relacionados",
          "Permitir abrir ayuda ampliada"
        ],
        "secondary": [
          "Reducir dudas de navegación o uso",
          "Servir como capa ligera de asistencia contextual"
        ]
