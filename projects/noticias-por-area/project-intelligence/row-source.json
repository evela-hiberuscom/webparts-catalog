        "productGoal": "Aumentar relevancia mostrando noticias alineadas con el contexto del área o audiencia."
      },
      "problem": {
        "business": "No todas las noticias son relevantes en todas las páginas.",
        "operational": "Se necesita una pieza de noticias contextual para áreas o departamentos específicos."
      },
      "objectives": {
        "primary": [
          "Mostrar noticias de un área concreta",
          "Permitir filtrar por etiqueta/categoría",
          "Reutilizar el mismo componente en varias áreas"
        ],
        "secondary": [
          "Ordenar por fecha o destacado",
          "Mostrar pocas noticias relevantes"
        ]
