        {
          "id": "RF-02",
          "text": "Mostrar persona o equipo reconocido, mensaje breve y fecha cuando existan."
        },
        {
          "id": "RF-03",
          "text": "Permitir abrir detalle cuando exista enlace."
        },
        {
          "id": "RF-04",
          "text": "Gestionar loading, empty, partialData y error."
        }
      ],
      "businessRules": [
        "Los reconocimientos más recientes se muestran primero.",
        "Si falta enlace, el reconocimiento sigue siendo informativo.",
        "Si falta foto, usar avatar por defecto cuando aplique."
