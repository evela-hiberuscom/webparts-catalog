    "technicalJson": {
      "architecture": {
        "webPart": "InternalServicesStatusWebPart",
        "pattern": "SPFx React + repository + mapper + evaluator",
        "components": [
          "InternalServicesStatus",
          "ServiceStatusCard",
          "StatusLegend",
          "RefreshActions"
        ],
        "services": [
          "InternalServicesStatusService",
          "ServiceStatusMapper",
          "StalenessEvaluator"
        ],
        "repositories": [
          "ServiceStatusRepository"
        ]
      },
      "contracts": {
        "IWebPartProps": {
          "dataSourceType": "SharePointList|JsonUrl|StaticConfig",
          "listTitleOrUrl": "string",
          "autoRefreshSeconds": "number",
          "showOnlyCritical": "boolean"
        },
        "IServiceStatus": {
          "id": "string",
          "name": "string",
          "status": "ok|warning|critical|maintenance|unknown",
          "criticality": "low|medium|high",
          "summary": "string",
          "updatedAt": "string|null",
          "detailUrl": "string|null"
        },
        "IViewModel": {
          "services": "IServiceStatus[]",
          "hasPartialData": "boolean",
          "lastUpdated": "string|null"
        }
      },
      "executionFlow": [
        "leer props",
        "resolver origen de datos",
        "leer registros",
        "mapear a IServiceStatus",
        "calcular stale",
        "renderizar"
      ],
      "algorithms": {
        "stale": "si now-updatedAt supera staleThresholdMinutes => badge stale/unknown",
        "sort": "critical > warning > maintenance > ok > unknown"
      },
      "performance": {
        "cache": "en memoria por origen",
        "retry": "1-2 reintentos",
        "autoRefresh": "timer con cleanup en unmount"
      },
      "errorMatrix": [
        {
          "condition": "lista no existe",
          "uiState": "error"
        },
        {
          "condition": "servicio sin updatedAt",
          "uiState": "partialData"
        },
        {
          "condition": "json inválido",
          "uiState": "error"
        }
      ],
      "security": {
        "mode": "readOnly",
