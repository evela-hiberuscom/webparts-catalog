      "summary": {
        "oneLiner": "Muestra quién está de turno, de guardia o disponible en un periodo concreto, con horarios, cobertura y contacto rápido.",
        "productGoal": "Dar visibilidad operativa inmediata sobre disponibilidad de personas o equipos para soporte, operaciones y continuidad."
      },
      "problem": {
        "business": "Los usuarios no saben quién cubre una función o servicio en un momento determinado.",
        "operational": "Soporte y operaciones pierden tiempo localizando la guardia correcta o comprobando coberturas manualmente."
      },
      "objectives": {
        "primary": [
          "Mostrar guardia actual o siguiente",
          "Mostrar persona/equipo, ventana horaria y contacto",
          "Soportar vista actual y próximas coberturas",
          "Marcar huecos o conflictos de cobertura"
        ],
        "secondary": [
          "Permitir filtrar por servicio o equipo",
          "Permitir abrir Teams/mail/perfil",
          "Servir como tarjeta reusable para on-call u horarios"
        ]
      },
      "users": [
        {
          "role": "Empleado",
          "needs": [
            "saber a quién contactar",
