      },
      "summary": {
        "oneLiner": "Muestra reuniones, demos, eventos o hitos próximos del equipo en una vista compacta y contextual.",
        "productGoal": "Ayudar a que el equipo tenga visibilidad rápida de su agenda compartida sin abrir el calendario completo."
      },
      "problem": {
        "business": "La actividad del equipo se fragmenta entre calendarios, chats y reuniones, y se pierde visibilidad de lo próximo.",
        "operational": "Los miembros del equipo no siempre saben qué reuniones, demos o hitos son inminentes."
      },
      "objectives": {
        "primary": [
          "Mostrar próximos eventos del equipo",
          "Permitir abrir el evento o calendario",
          "Ordenar por fecha y hora",
          "Distinguir hoy, mañana y próximos días"
        ],
        "secondary": [
          "Filtrar por tipo de evento",
          "Mostrar ubicación o enlace de reunión",
          "Servir como bloque de portada de equipo"
        ]
      },
      "users": [
        {
          "role": "Miembro del equipo",
          "needs": [
            "ver qué viene a continuación"
          ]
        },
        {
          "role": "Team lead",
          "needs": [
            "dar visibilidad a agenda compartida"
          ]
        }
      ],
      "scope": {
        "in": [
          "Eventos próximos",
          "Fecha y hora",
          "Tipo/etiqueta",
          "Ubicación o link de reunión",
          "Acción abrir detalle"
        ],
        "out": [
          "edición de eventos",
          "gestión avanzada del calendario",
          "reserva o RSVP dentro de la web part"
