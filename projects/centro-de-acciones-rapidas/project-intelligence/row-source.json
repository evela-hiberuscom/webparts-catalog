      "summary": {
        "oneLiner": "Agrupa acciones frecuentes de un área o perfil para lanzar procesos, herramientas o páginas clave en pocos clics.",
        "productGoal": "Concentrar las acciones corporativas más utilizadas en un bloque compacto, configurable y reusable."
      },
      "problem": {
        "business": "Los usuarios repiten navegación a zonas profundas para ejecutar las mismas acciones.",
        "operational": "Sin un centro de acciones se dispersan accesos y disminuye la adopción de procesos estándar."
      },
      "objectives": {
        "primary": [
          "Mostrar acciones frecuentes de forma compacta",
          "Permitir lanzar procesos o herramientas rápidamente",
          "Adaptarse a área o audiencia",
          "Servir de bloque reusable en distintas páginas"
        ],
        "secondary": [
          "Mostrar iconos, categorías y etiquetas",
          "Filtrar por grupo o contexto",
          "Ordenar por prioridad"
        ]
      },
