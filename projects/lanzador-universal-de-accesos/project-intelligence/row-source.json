    "technicalJson": {
      "architecture": {
        "webPart": "UniversalLauncherWebPart",
        "pattern": "SPFx React + repository + priority/category filter",
        "components": [
          "UniversalLauncher",
          "LaunchCard",
          "LaunchFilterBar"
        ],
        "services": [
          "LaunchCatalogService"
        ],
        "repositories": [
          "LaunchRepository"
        ]
      },
      "contracts": {
        "IWebPartProps": {
          "dataSourceType": "SharePointList|JsonUrl|StaticConfig",
          "listTitleOrUrl": "string",
          "defaultCategory": "string|undefined",
          "maxItems": "number",
          "openInNewTab": "boolean"
        },
        "ILaunchItem": {
          "id": "string",
          "title": "string",
          "category": "string|null",
          "description": "string|null",
          "icon": "string|null",
          "priority": "number|null",
          "featured": "boolean",
          "openUrl": "string|null"
        },
        "IViewModel": {
          "items": "ILaunchItem[]",
          "categories": "string[]",
          "hasPartialData": "boolean"
        }
      },
      "executionFlow": [
        "leer props",
        "resolver origen",
        "leer catálogo de accesos",
        "normalizar categoría/prioridad/icono",
        "ordenar",
        "aplicar filtro",
        "renderizar"
      ],
      "algorithms": {
        "sort": "featured desc + priority asc/null-last + title asc",
        "filter": "por categoría cuando exista"
      },
      "performance": {
        "cache": "por origen",
        "retry": "1-2 reintentos"
      },
      "errorMatrix": [
        {
          "condition": "sin openUrl",
          "uiState": "partialData"
        },
        {
          "condition": "sin icono",
          "uiState": "ready"
        }
      ],
      "security": {
        "mode": "launcher",
        "rules": [
          "sanitizar openUrl",
          "marcar enlaces externos",
          "respetar openInNewTab configurado"
        ]
      },
      "telemetry": {
        "events": [
          "launcher_loaded",
          "launcher_partial",
          "launcher_error",
          "launcher_opened"
        ],
        "properties": [
          "itemCount",
          "categoryFilter",
          "hasPartialData"
        ]
      },
      "testing": {
        "unit": [
