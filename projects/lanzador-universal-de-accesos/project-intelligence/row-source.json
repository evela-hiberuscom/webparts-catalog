      "summary": {
        "oneLiner": "Muestra un grid configurable de accesos a apps, sites, formularios y utilidades corporativas.",
        "productGoal": "Reducir fricción para llegar a herramientas y recursos frecuentes desde una única pieza reusable."
      },
      "problem": {
        "business": "Las intranets suelen dispersar accesos en menús, páginas y enlaces inconexos.",
        "operational": "Los usuarios pierden tiempo buscando herramientas de uso común o acaban usando marcadores locales inconsistentes."
      },
      "objectives": {
        "primary": [
          "Centralizar accesos frecuentes en un grid simple",
          "Mostrar icono, título y categoría",
          "Permitir apertura rápida y segura",
          "Ordenar por prioridad o grupo"
        ],
        "secondary": [
          "Soportar audience targeting si el origen lo permite",
          "Filtrar por categoría",
          "Mostrar destacados"
        ]
      },
