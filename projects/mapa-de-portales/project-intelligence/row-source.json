      "summary": {
        "oneLiner": "Ofrece una vista estructurada de hubs, sites, áreas y utilidades para navegar la intranet como un mapa lógico.",
        "productGoal": "Hacer comprensible la estructura de portales y reducir desorientación dentro de la intranet."
      },
      "problem": {
        "business": "Las intranets complejas pierden claridad cuando la estructura de hubs y sites no es evidente para el usuario.",
        "operational": "Los usuarios no siempre saben dónde encaja cada portal o área y terminan navegando a ciegas."
      },
      "objectives": {
        "primary": [
          "Representar la estructura de portales y áreas",
          "Permitir navegar por niveles lógicos",
          "Ayudar a descubrir sites y espacios relacionados"
        ],
        "secondary": [
          "Mostrar jerarquía o relaciones",
          "Permitir destacar hubs principales",
          "Servir como guía de orientación"
        ]
      },
      "users": [
        {
          "role": "Empleado",
          "needs": [
            "entender cómo se organiza la intranet"
          ]
        },
        {
          "role": "Owner intranet",
          "needs": [
            "explicar la estructura de portales"
          ]
        }
      ],
      "scope": {
        "in": [
          "Mapa lógico de hubs/sites/áreas",
          "Niveles jerárquicos o relacionados",
          "Acción abrir portal"
        ],
        "out": [
          "grafo interactivo complejo",
          "descubrimiento semántico avanzado",
          "edición de estructura desde la web part"
        ]
      },
