    "technicalJson": {
      "architecture": {
        "webPart": "PortalMapWebPart",
        "pattern": "SPFx React + hierarchy builder + repository",
        "components": [
          "PortalMap",
          "PortalTree",
          "PortalNodeItem",
          "PortalViewSwitcher"
        ],
        "services": [
          "PortalMapService",
          "PortalHierarchyBuilder"
        ],
        "repositories": [
          "PortalMapRepository"
        ]
      },
      "contracts": {
        "IWebPartProps": {
          "dataSourceType": "SharePointList|JsonUrl|StaticConfig",
          "listTitleOrUrl": "string",
          "viewMode": "tree|grouped|cards",
          "maxDepth": "number"
        },
        "IPortalNode": {
          "id": "string",
          "title": "string",
          "nodeType": "hub|site|area|utility|unknown",
          "parentId": "string|null",
          "description": "string|null",
          "openUrl": "string|null",
          "featured": "boolean"
        },
        "IViewModel": {
          "roots": "IPortalNode[]",
          "flatItems": "IPortalNode[]",
          "hasPartialData": "boolean"
        }
      },
      "executionFlow": [
        "leer props",
        "resolver origen",
        "leer nodos",
        "construir jerarquía o agrupación",
        "aplicar maxDepth",
        "renderizar"
      ],
      "algorithms": {
        "hierarchy": "construir raíces y hijos por parentId",
        "invalidParent": "mover a root-orphans si no existe padre",
        "cycleGuard": "detectar ciclos y degradar a flat/grouped view"
      },
      "performance": {
        "cache": "por origen",
        "retry": "1-2 reintentos"
      },
      "errorMatrix": [
        {
          "condition": "parent ausente",
          "uiState": "partialData"
        },
        {
          "condition": "cycle detected",
          "uiState": "partialData con fallback"
        },
        {
          "condition": "sin openUrl",
          "uiState": "ready"
        }
      ],
      "security": {
        "mode": "readOnly",
        "rules": [
          "sanitizar openUrl"
        ]
      },
      "telemetry": {
