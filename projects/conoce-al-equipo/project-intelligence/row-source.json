        "status": "ready-for-implementation"
      },
      "summary": {
        "oneLiner": "Presenta a las personas de un equipo con foto, rol, descripción breve y enlaces de contacto o perfil.",
        "productGoal": "Facilitar reconocimiento, cercanía y contexto humano dentro de equipos o áreas."
      },
      "problem": {
        "business": "En equipos distribuidos o grandes, no siempre es fácil saber quién es quién y a qué se dedica cada persona.",
        "operational": "Las páginas de equipo necesitan una forma clara y reusable de presentar a sus miembros."
      },
      "objectives": {
        "primary": [
          "Mostrar miembros del equipo con información básica",
          "Permitir abrir perfil o contacto",
          "Destacar rol y presentación breve"
        ],
        "secondary": [
          "Ordenar por rol, orden manual o seniority",
          "Servir para equipos pequeños o medianos"
        ]
      },
      "users": [
        {
          "role": "Empleado",
          "needs": [
            "conocer a las personas del equipo"
          ]
        },
        {
          "role": "Manager/Owner de equipo",
          "needs": [
            "presentar al equipo de forma clara"
          ]
        }
      ],
      "scope": {
        "in": [
          "Foto/avatar",
          "nombre",
          "rol",
          "bio corta",
          "contacto o perfil",
          "orden configurable"
        ],
        "out": [
          "directorio global completo",
          "org chart complejo",
          "edición de perfiles desde la web part"
