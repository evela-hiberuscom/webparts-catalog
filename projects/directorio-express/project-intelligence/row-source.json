      "summary": {
        "oneLiner": "Permite localizar rápidamente personas por nombre, rol, área o dato básico de contacto desde una versión ligera del directorio corporativo.",
        "productGoal": "Reducir el tiempo para encontrar a la persona adecuada sin abrir un directorio completo."
      },
      "problem": {
        "business": "Encontrar a la persona correcta en la organización puede llevar demasiado tiempo.",
        "operational": "Las páginas de área necesitan un directorio rápido y reutilizable, no un portal completo de people search."
      },
      "objectives": {
        "primary": [
          "Buscar y listar personas de forma ligera",
          "Mostrar nombre, rol y contacto básico",
          "Permitir abrir perfil o iniciar contacto"
        ],
        "secondary": [
          "Filtrar por área o rol",
          "Servir como componente reusable en páginas de equipo o área"
        ]
      },
      "users": [
        {
          "role": "Empleado",
          "needs": [
            "encontrar una persona rápidamente"
          ]
        },
        {
          "role": "Manager/Owner de área",
          "needs": [
            "ofrecer un directorio corto y útil"
          ]
        }
      ],
      "scope": {
        "in": [
          "Listado ligero de personas",
