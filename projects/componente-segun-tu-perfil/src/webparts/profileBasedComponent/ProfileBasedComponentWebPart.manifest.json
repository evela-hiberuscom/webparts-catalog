  "requiresCustomScript": false,
  "supportedHosts": ["SharePointWebPart", "TeamsPersonalApp", "TeamsTab", "SharePointFullPage"],
  "supportsThemeVariants": true,

  "preconfiguredEntries": [{
    "groupId": "5c03119e-3074-46fd-976b-c60198311f70", // Advanced
    "group": { "default": "Advanced" },
    "title": { "default": "Componente según tu perfil" },
    "description": { "default": "Renderiza contenido, accesos o mensajes distintos según atributos del perfil o segmentación del usuario." },
    "officeFabricIconFontName": "Page",
    "properties": {
      "title": "Componente según tu perfil",
      "description": "Personaliza el bloque según audiencia y origen de variantes.",
      "dataSourceType": "SharePointList",
      "listTitleOrUrl": "ProfileVariants",
      "jsonUrl": "",
      "staticConfigJson": "",
      "audienceMode": "hybrid",
      "fallbackMode": "generic",
      "profileTokens": "",
      "maxItems": 3
    }
  }]
}
