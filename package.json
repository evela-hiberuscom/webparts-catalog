{
  "name": "paquete-webparts",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evela-hiberuscom/webparts-catalog.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync:airtable": "node ./scripts/sync-airtable-catalog.mjs",
    "bootstrap:contexts": "node ./scripts/bootstrap-project-contexts.mjs",
    "orchestrate:foundation": "npm run sync:airtable && npm run bootstrap:contexts",
    "scaffold:spfx": "node ./scripts/scaffold-spfx-project.mjs",
    "prepare:spfx": "node ./scripts/prepare-spfx-project.mjs",
    "record:issue": "node ./scripts/record-issue.mjs",
    "progress:board": "node ./scripts/render-progress-board.mjs",
    "progress:trace": "node ./scripts/render-agent-trace.mjs",
    "audit:redteam": "node ./scripts/generate-red-team-audit.mjs",
    "ci:projects": "node ./scripts/ci-validate-projects.mjs",
    "ci:projects:dry-run": "node ./scripts/ci-validate-projects.mjs --dry-run",
    "check:locks": "node ./scripts/check-lockfile-consistency.mjs",
    "check:pinned-deps": "node ./scripts/check-pinned-project-deps.mjs",
    "check:secrets": "node ./scripts/secret-scan.mjs",
    "check:audit-remediation": "node ./scripts/audit-remediation-checks.mjs"
